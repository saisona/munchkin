loki.write "local" {
    endpoint {
        url = "http://loki:3100/loki/api/v1/push"
    }
}

otelcol.receiver.otlp "otlp_receiver" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlp.internal.input,]
  }
}

otelcol.exporter.otlp "internal" {
  client {
    endpoint = "tempo:4317"
    tls {
			insecure = true
		}
  }
}
