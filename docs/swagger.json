{
    "swagger": "2.0",
    "info": {
        "description": "This is the API for Munchin game backend",
        "title": "Munchin API",
        "contact": {},
        "version": "0.1"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/healthz": {
            "get": {
                "description": "Works as a probe like healhtz check",
                "tags": [
                    "healt"
                ],
                "summary": "Check health of the service",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/lobby": {
            "get": {
                "description": "List all game lobbies based",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "lobby"
                ],
                "summary": "List Lobbies",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/lobbies.LobbyListResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "lobbies.LobbyListItem": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "playerCount": {
                    "type": "integer"
                },
                "state": {
                    "$ref": "#/definitions/lobbies.LobbyState"
                }
            }
        },
        "lobbies.LobbyListResponse": {
            "type": "object",
            "properties": {
                "hasMore": {
                    "type": "boolean"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/lobbies.LobbyListItem"
                    }
                },
                "limit": {
                    "type": "integer"
                },
                "offset": {
                    "type": "integer"
                }
            }
        },
        "lobbies.LobbyState": {
            "type": "string",
            "enum": [
                "ACTIVE",
                "FULL",
                "IN_GAME"
            ],
            "x-enum-varnames": [
                "StateAvailable",
                "StateFull",
                "StateInGame"
            ]
        }
    }
}